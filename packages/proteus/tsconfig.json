{
  "extends": "../../tsconfig.pkg.json",
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "paths": {
      "@optiaxiom/icons": ["../icons/src"],
      "@optiaxiom/react": ["../react/src"],
      "@optiaxiom/react/css-runtime": ["../react/src/css-runtime"],
      "@optiaxiom/react/unstable": ["../react/src/unstable"]
    }
  },
  "include": [
    ".",
    "package.json",
    "src/schema/public-schema.json",
    "src/schema/runtime-schema.json"
  ],
  "exclude": ["dist", "lib", "node_modules"],
  "references": [
    { "path": "../globals" },
    { "path": "../icons" },
    { "path": "../react" }
  ]
}
