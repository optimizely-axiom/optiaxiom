{
  "name": "optiaxiom",
  "packageManager": "pnpm@10.13.1",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "license": "Apache-2.0",
  "scripts": {
    "build": "pnpm -F \"./packages/**\" build",
    "bundle-size": "oas-bundle-size",
    "design-tokens": "oas-design-tokens",
    "dev": "pnpm run --parallel -F !web-components dev",
    "dev:docs": "pnpm -F docs... --parallel dev",
    "dev:storybook": "pnpm -F storybook... --parallel dev",
    "lint": "oas-lint",
    "release": "pnpm build && changeset publish",
    "test": "vitest run --project=@optiaxiom/globals --project=@optiaxiom/react"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@optiaxiom/shared": "workspace:^",
    "@rollup/pluginutils": "^5.3.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@typescript/native-preview": "7.0.0-dev.20260421.2",
    "@vanilla-extract/integration": "^8.0.10",
    "@vanilla-extract/rollup-plugin": "^1.5.3",
    "@vanilla-extract/vite-plugin": "^5.2.2",
    "@vitest/browser": "^3.2.4",
    "concurrently": "^9.2.1",
    "esbuild": "0.17.6",
    "eslint": "^9.39.4",
    "eslint-plugin-perfectionist": "^4.15.1",
    "eslint-plugin-testing-library": "^7.16.2",
    "happy-dom": "^18.0.1",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "oxlint-tsgolint": "^0.21.1",
    "playwright": "^1.59.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "rolldown": "1.0.2",
    "rolldown-plugin-dts": "^0.25.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4",
    "wait-on": "^8.0.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "edgedriver",
      "esbuild",
      "geckodriver",
      "msw",
      "sharp"
    ],
    "patchedDependencies": {
      "@vanilla-extract/sprinkles": "patches/@vanilla-extract__sprinkles.patch",
      "nextra-theme-docs": "patches/nextra-theme-docs.patch",
      "react-docgen-typescript": "patches/react-docgen-typescript.patch"
    }
  }
}
